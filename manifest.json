{
  "manifest_version": 3,
  "name": "UnmapJS – Source Map Exposure Scanner",
  "version": "1.0.0",
  "description": "Finds exposed JavaScript source maps and downloads recoverable source files as a ZIP archive.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "tabs",
    "notifications"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UnmapJS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
